{
  "name": "@coder/ai-sdk-agent",
  "version": "0.3.0",
  "description": "A Vercel AI SDK-compliant agent backed by Coder Agents, Coder's server-side agent runtime. `new CoderAgent()` returns a real AI SDK Agent (generate/stream).",
  "keywords": [
    "agent",
    "ai",
    "ai-sdk",
    "coder",
    "llm",
    "streaming",
    "tools",
    "vercel-ai-sdk"
  ],
  "homepage": "https://github.com/coder/ai-sdk/tree/main/packages/agent#readme",
  "bugs": {
    "url": "https://github.com/coder/ai-sdk/issues"
  },
  "license": "Apache-2.0",
  "author": "Coder Technologies, Inc. (https://coder.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coder/ai-sdk.git",
    "directory": "packages/agent"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run test/unit",
    "test:unit": "vitest run test/unit",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest",
    "example:generate": "tsx examples/01-generate.ts",
    "example:stream": "tsx examples/02-stream.ts",
    "example:tool": "tsx examples/03-custom-tool.ts",
    "example:multi-turn": "tsx examples/04-multi-turn.ts",
    "example:file": "tsx examples/05-file-upload.ts",
    "example:structured": "tsx examples/06-structured-output.ts"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "4.0.3",
    "@ai-sdk/react": "4.0.20",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "ai": "^7.0.19",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "ai": "^7.0.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
